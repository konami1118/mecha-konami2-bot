# サービスアカウントキーのパス（ローカル開発用）
# サーバー上では GOOGLE_APPLICATION_CREDENTIALS 環境変数を直接設定してください
GOOGLE_APPLICATION_CREDENTIALS=key/service_account.json

# 応募受付を許可するロールID（Discordで開発者モードを有効にしてロールを右クリック→IDをコピー）
ADMIN_ROLE_ID=your_role_id_here

# セッションタイムアウト（秒）（任意、デフォルト: 900）
SESSION_TIMEOUT_SECONDS=900

# ============================================================
# 以下は Google Secret Manager に登録してください（.envには書かない）
# ============================================================
# Secret名: DISCORD_BOT_TOKEN   → Discord Bot Token
# Secret名: DISCORD_SERVER_ID   → Discord サーバーID
# Secret名: SPREADSHEET_ID      → Google スプレッドシートID
